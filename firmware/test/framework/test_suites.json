  "test_configuration": {
    "default_timeout": 300,
    "parallel_execution": false,
    "continue_on_failure": true,
    "generate_reports": true,
    "report_format": ["html", "json"],
    "notification_channels": ["console", "file"],
    "quality_gates": {
      "minimum_success_rate": 95.0,
      "maximum_failure_rate": 5.0,
      "maximum_execution_time": 3600,
      "maximum_memory_usage": 200000
    }
  }
